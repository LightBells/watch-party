{
  "name": "watch-party",
  "version": "1.0.0",
  "description": "リアルタイム動画視聴同期アプリケーション",
  "main": "dist/server/index.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:extension": "webpack --config extension/webpack.config.js",
    "build": "npm run build:server && npm run build:extension",
    "start": "node dist/server/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "gcp-build": "npm run build"
  },
  "keywords": [
    "watch-party",
    "sync",
    "video",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/firestore": "^6.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.7",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.48.0",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "webpack": "^5.105.0",
    "webpack-cli": "^5.1.4"
  }
}
